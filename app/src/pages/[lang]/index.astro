---
import CrumbArt from '../../components/CrumbArt.astro';
import Layout from '../../components/Layout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { fmt, getDict, withBase } from '../../i18n';
import { computeStats, getAllRecipes, toIndexEntry } from '../../lib/recipes';
import { LANGS, type Lang } from '../../lib/taxonomy';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = getDict(lang);
const recipes = await getAllRecipes();
const stats = computeStats(recipes.map((r) => r.data));

// Deterministic bread of the day: day number at build time, modulo the recipe
// count. Stable within a day, no server needed, no per-language drift.
const buildDay = Math.floor(Date.now() / 86_400_000);
const breadOfDay = recipes.length > 0 ? recipes[buildDay % recipes.length] : recipes[0];
const breadOfDayEntry = breadOfDay ? toIndexEntry(breadOfDay.data, lang) : null;

const featuredSlugs = ['country-sourdough', 'baguette-tradition', 'vollkornbrot'];
const featured = featuredSlugs
  .map((s) => recipes.find((r) => r.data.slug === s))
  .filter((r) => r !== undefined)
  .slice(0, 3);
const fallback = recipes.slice(0, 3 - featured.length);
const featuredEntries = [...featured, ...fallback]
  .slice(0, 3)
  .map((r) => toIndexEntry(r.data, lang));

const hero = recipes.find((r) => r.data.slug === 'country-sourdough') ?? recipes[0];

const sections = [
  {
    href: withBase(`/${lang}/breads/`),
    title: t.home.sections.atlasTitle,
    desc: t.home.sections.atlasDesc,
    art: { slug: 'panarium-atlas', family: 'hearth-loaf', crumb: 'open', hydrationPct: 78 },
  },
  {
    href: withBase(`/${lang}/lab/`),
    title: t.home.sections.labTitle,
    desc: t.home.sections.labDesc,
    art: { slug: 'panarium-lab', family: 'baguette', crumb: 'open', hydrationPct: 72 },
  },
  {
    href: withBase(`/${lang}/school/`),
    title: t.home.sections.schoolTitle,
    desc: t.home.sections.schoolDesc,
    art: {
      slug: 'panarium-school',
      family: 'pan-loaf',
      crumb: 'medium',
      hydrationPct: 68,
      ryePct: 60,
    },
  },
  {
    href: withBase(`/${lang}/finder/`),
    title: t.home.sections.finderTitle,
    desc: t.home.sections.finderDesc,
    art: { slug: 'panarium-finder', family: 'ring', crumb: 'tight', hydrationPct: 58 },
  },
] as const;
const atlasHref = withBase(`/${lang}/breads/`);
const labHref = withBase(`/${lang}/lab/`);
---

<Layout lang={lang} title={t.siteName} description={t.meta.home} current="home">
 <section class="hero wrap">
 <div class="hero-text stagger">
 <p class="kicker">{t.home.heroKicker}</p>
 <h1 class="hero-title" set:html={t.home.heroTitle.replace(/formule\.|Formel\.|fórmula\.|formula\.|formulă\./, (m) => `<em>${m}</em>`)} />
 <p class="lead">
 {fmt(t.home.heroLead, { n: stats.recipes, c: stats.countries, l: LANGS.length })}
 </p>
 <div class="hero-cta">
 <a class="btn btn-primary" href={atlasHref}>{t.home.ctaAtlas}</a>
 <a class="btn" href={labHref}>{t.home.ctaLab}</a>
 </div>
 <dl class="hero-stats mono">
 <div><dt>{stats.recipes}</dt><dd>{t.home.statRecipes}</dd></div>
 <div><dt>{stats.countries}</dt><dd>{t.home.statCountries}</dd></div>
 <div><dt>{stats.sourdoughs}</dt><dd>{t.home.statSourdoughs}</dd></div>
 <div><dt>{Math.round(stats.medianHydration)}%</dt><dd>{t.home.statHydration}</dd></div>
 </dl>
 </div>
 <div class="hero-art" aria-hidden="true">
 {
 hero && (
 <CrumbArt
 input={{
 slug: hero.data.slug,
 family: hero.data.family,
 crumb: hero.data.crumb,
 hydrationPct: hero.data.formula.hydrationPct,
 wholegrainPct: hero.data.diet.wholegrainPct,
 bakeTempC: hero.data.bake.tempC,
 }}
 label=""
 />
 )
 }
 </div>
 </section>

 <section class="wrap sections-grid stagger">
 {
 sections.map((s) => (
 <a class="section-card card" href={s.href}>
 <div class="mini-art" aria-hidden="true">
 <CrumbArt input={s.art as never} label="" />
 </div>
 <h2>{s.title}</h2>
 <p>{s.desc}</p>
 <span class="go" aria-hidden="true">
 →
 </span>
 </a>
 ))
 }
 </section>

  <section class="wrap bread-of-day" style="margin-top: clamp(40px, 7vw, 80px);">
  <p class="kicker">{t.home.breadOfDay}</p>
  <div class="card-grid stagger">
  {breadOfDayEntry && <RecipeCard e={breadOfDayEntry} lang={lang} t={t} />}
  </div>
  </section>

  <section class="wrap" style="margin-top: clamp(40px, 7vw, 80px);">
  <p class="kicker">{t.home.featured}</p>
  <div class="card-grid stagger">
  {featuredEntries.map((e) => <RecipeCard e={e} lang={lang} t={t} />)}
  </div>
  </section>
</Layout>

<style>
 .hero {
 display: grid;
 grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
 gap: clamp(20px, 5vw, 64px);
 align-items: center;
 padding-block: clamp(40px, 7vw, 96px) clamp(24px, 4vw, 48px);
 }
 .hero-title {
 font-size: clamp(2.6rem, 6.2vw, 4.6rem);
 margin-bottom: 0.35em;
 }
 .hero-title :global(em) {
 color: var(--crust);
 font-style: italic;
 font-variation-settings: 'SOFT' 100, 'WONK' 1;
 }
 .hero-cta {
 display: flex;
 gap: 12px;
 flex-wrap: wrap;
 margin-top: 8px;
 }
 .hero-stats {
 display: flex;
 gap: clamp(18px, 3vw, 40px);
 margin: 34px 0 0;
 padding-top: 18px;
 border-top: 1px solid var(--line);
 }
 .hero-stats dt {
 font-family: var(--font-display);
 font-size: 1.7rem;
 font-weight: 600;
 color: var(--crust);
 }
 .hero-stats dd {
 margin: 0;
 font-size: 0.72rem;
 text-transform: uppercase;
 letter-spacing: 0.12em;
 color: var(--ink-faint);
 }
 .hero-art :global(svg) {
 width: 100%;
 filter: drop-shadow(0 18px 40px rgba(84, 56, 18, 0.22));
 transform: rotate(-1.2deg);
 }
 @media (max-width: 860px) {
 .hero {
 grid-template-columns: 1fr;
 }
 .hero-art {
 max-width: 340px;
 margin-inline: auto;
 }
 }
 .sections-grid {
 display: grid;
 grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
 gap: 18px;
 }
 .section-card {
 position: relative;
 padding: 22px;
 text-decoration: none;
 color: var(--ink);
 transition: transform 0.18s ease, border-color 0.18s ease;
 overflow: hidden;
 }
 .section-card:hover {
 transform: translateY(-4px);
 border-color: var(--gold);
 }
 .section-card h2 {
 font-size: 1.35rem;
 margin: 8px 0 6px;
 }
 .section-card p {
 color: var(--ink-muted);
 font-size: 0.95rem;
 margin: 0;
 }
 .section-card .go {
 position: absolute;
 right: 18px;
 top: 16px;
 font-size: 1.3rem;
 color: var(--crust);
 transition: transform 0.18s ease;
 }
 .section-card:hover .go {
 transform: translateX(4px);
 }
 .mini-art {
 width: 74px;
 }
</style>
