---
import CrumbArt from '../../../components/CrumbArt.astro';
import DifficultyStalks from '../../../components/DifficultyStalks.astro';
import Layout from '../../../components/Layout.astro';
import RecipeCard from '../../../components/RecipeCard.astro';
import FormulaCard from '../../../components/react/FormulaCard';
import TimeRibbon from '../../../components/TimeRibbon.astro';
import { fmt, getDict, pick, withBase } from '../../../i18n';
import { flagEmoji, formatMinutes, regionName } from '../../../lib/format';
import {
  getAllRecipes,
  isGlutenFree,
  ryePct,
  toIndexEntry,
  wholegrainPct,
} from '../../../lib/recipes';
import { topSimilar } from '../../../lib/recommend';
import { LANGS, type Lang } from '../../../lib/taxonomy';
import { cToF } from '../../../lib/units';

export async function getStaticPaths() {
  const recipes = await getAllRecipes();
  return LANGS.flatMap((lang) =>
    recipes.map((r) => ({ params: { lang, slug: r.data.slug }, props: { slug: r.data.slug } })),
  );
}

const lang = Astro.params.lang as Lang;
const t = getDict(lang);
const recipes = await getAllRecipes();
const entry = recipes.find((r) => r.data.slug === Astro.params.slug);
if (!entry) return Astro.redirect(withBase(`/${lang}/breads/`));
const r = entry.data;
const rName = pick(r.name, lang);
const rDesc = pick(r.description, lang);

const entries = recipes.map((x) => toIndexEntry(x.data, lang));
const self = entries.find((e) => e.slug === r.slug);
const similar = self ? topSimilar(self, entries, 4) : [];

const whole = wholegrainPct(r);
const rye = ryePct(r);
const gf = isGlutenFree(r);
const keeps =
  r.keeping.freshDays <= 1 ? t.recipe.dayOne : fmt(t.recipe.days, { n: r.keeping.freshDays });
const sourceHost = new URL(r.source.url).hostname.replace(/^www\./, '');

const labParams = new URLSearchParams();
labParams.set('st', 'custom');
labParams.set('p', String(r.yield.count));
labParams.set('w', String(r.yield.pieceGrams));
labParams.set('h', String(r.formula.hydrationPct));
labParams.set('s', String(r.formula.saltPct));
labParams.set('su', String(r.formula.sugarPct ?? 0));
labParams.set('fa', String(r.formula.fatPct ?? 0));
labParams.set(
  'm',
  r.leaven === 'sourdough' ? 'levain' : r.leaven === 'hybrid' ? 'hybrid' : 'yeast',
);
labParams.set('blend', r.formula.flours.map((f) => `${f.type}:${f.pct}`).join('|'));
// Levain weight is roughly twice the prefermented flour at 100% levain hydration,
// so a levain dough lands in the Lab with a workable amount rather than 0%.
if (r.formula.prefermentedFlourPct && (r.leaven === 'sourdough' || r.leaven === 'hybrid')) {
  labParams.set('lp', String(Math.round(r.formula.prefermentedFlourPct * 2)));
  labParams.set('lh', '100');
}
const labHref = withBase(`/${lang}/lab/?${labParams.toString()}`);
---

<Layout lang={lang} title={rName} description={rDesc} current="atlas">
 <article class="wrap recipe">
 <p class="crumbtrail no-print">
 <a href={withBase(`/${lang}/breads/`)}>← {t.common.backToAtlas}</a>
 </p>

 <header class="recipe-head">
 <div>
 <p class="kicker">
 {flagEmoji(r.origin.country)} {regionName(r.origin.country, lang)}{r.origin.region ? `, ${r.origin.region}` : ''}
 </p>
 <h1>
 {rName}
 {r.name.native && r.name.native !== rName && (
 <span class="native">{r.name.native}</span>
 )}
 </h1>
 {r.kitchenTested && (
 <p class="tested-mark">
 <span class="chip chip-tested">
 {t.recipe.kitchenTested}
 {r.kitchenTested.date && (
 <span class="tested-date">· {fmt(t.recipe.kitchenTestedOn, { date: r.kitchenTested.date })}</span>
 )}
 </span>
 </p>
 )}
 <p class="lead">{rDesc}</p>
 <div class="chips">
 <span class="chip chip-static">{t.taxonomy.leaven[r.leaven]}</span>
 <span class="chip chip-static">{t.taxonomy.family[r.family]}</span>
 {r.flavors.map((f) => (
 <span class="chip chip-static">{t.taxonomy.flavor[f]}</span>
 ))}
 {r.purposes.map((p) => (
 <span class="chip chip-static">{t.taxonomy.purpose[p]}</span>
 ))}
 {r.diet.vegan && <span class="chip chip-static">{t.search.vegan}</span>}
 {gf && <span class="chip chip-static">{t.search.glutenFree}</span>}
 </div>
 </div>
 </header>

 <div class="recipe-grid">
 <aside class="plate">
 <div class="card pad plate-card">
 <CrumbArt
 input={{
 slug: r.slug,
 family: r.family,
 crumb: r.crumb,
 hydrationPct: r.formula.hydrationPct,
 wholegrainPct: whole,
 ryePct: rye,
 sugarPct: r.formula.sugarPct,
 flavors: r.flavors,
 bakeTempC: r.bake.tempC,
 }}
 label={rName}
 />
 <table class="ledger spec">
 <tbody>
 <tr>
 <td>{t.recipe.hydration}</td>
 <td class="num">
 <span class="meter">
 <span class="track"><span class="fill" style={`width:${Math.min(100, (r.formula.hydrationPct / 110) * 100)}%`}></span></span>
 {r.formula.hydrationPct}%
 </span>
 </td>
 </tr>
 <tr><td>{t.recipe.salt}</td><td class="num">{r.formula.saltPct}%</td></tr>
 {r.formula.prefermentedFlourPct !== undefined && (
 <tr><td>{t.recipe.prefermented}</td><td class="num">{r.formula.prefermentedFlourPct}%</td></tr>
 )}
 {whole > 0 && <tr><td>{t.recipe.wholegrain}</td><td class="num">{Math.round(whole)}%</td></tr>}
 <tr><td>{t.recipe.crumb}</td><td class="num">{t.taxonomy.crumb[r.crumb]}</td></tr>
 <tr><td>{t.recipe.crust}</td><td class="num">{t.taxonomy.crust[r.crust]}</td></tr>
 <tr>
 <td>{t.recipe.difficulty}</td>
 <td class="num">
 <DifficultyStalks level={r.difficulty} label={t.recipe.difficultyNames[r.difficulty as 1 | 2 | 3 | 4 | 5]} />
 </td>
 </tr>
 <tr><td>{t.recipe.keepsLabel}</td><td class="num">{keeps}{r.keeping.freezes ? ' ❄' : ''}</td></tr>
 <tr>
 <td>{t.recipe.oven}</td>
 <td class="num">{r.bake.tempC} °C / {cToF(r.bake.tempC)} °F</td>
 </tr>
 </tbody>
 </table>
 <p class="fine">
 {t.taxonomy.vessel[r.bake.vessel]}{r.bake.steam ? ` · ${t.recipe.steam}` : ''}
 </p>
 {r.equipment.length > 0 && (
 <div class="chips">
 {r.equipment.map((eq) => (
 <span class="chip chip-static">{t.taxonomy.equipment[eq]}</span>
 ))}
 </div>
 )}
 <div class="card pad soft">
 <TimeRibbon time={r.time} t={t} />
 </div>
 </div>
 </aside>

 <div class="content">
  <section>
  <h2>
  {t.recipe.formula}
  {r.formula.confidence && (
  <span class="chip chip-static">
  {r.formula.confidence === 'estimated' ? t.recipe.estimated : t.recipe.fromSource}
  </span>
  )}
  </h2>
  <p class="fine mono">
 {fmt(t.recipe.forYield, { count: r.yield.count, grams: r.yield.pieceGrams })}
 {r.yield.shape ? ` · ${r.yield.shape}` : ''}
  </p>
 <FormulaCard
 client:visible
 ingredients={r.ingredients}
 yieldCount={r.yield.count}
 yieldGrams={r.yield.pieceGrams}
 lang={lang}
 t={t}
 />
 <p class="lab-link no-print">
 <a class="btn" href={labHref}>{t.recipe.openInLab}</a>
 </p>
 </section>

  <section>
  <h2>{t.recipe.method}</h2>
  <ol class="method">
  {r.method.map((step) => (
  <li>
  <h3>{step.title[lang] ?? step.title.en}</h3>
  <p>{step.summary[lang] ?? step.summary.en}</p>
  </li>
  ))}
  </ol>
  {lang !== 'en' && !r.method.some((s) => s.title[lang] || s.summary[lang]) && (
  <p class="fine">{t.recipe.methodEnglishOnly}</p>
  )}
  {r.kitchenTested?.note && (
  <blockquote class="kitchen-note">
  <p class="kitchen-note-label">{t.recipe.kitchenNote}</p>
  <p class="kitchen-note-text">{r.kitchenTested.note}</p>
  </blockquote>
  )}
  {r.keeping.note && <p class="fine">{r.keeping.note}</p>}
  </section>

 <section class="card pad source-card">
 <h3>{t.recipe.source}</h3>
 <p>
 <a href={r.source.url} rel="noopener nofollow" target="_blank">
 {t.recipe.viewSource}, {sourceHost}
 </a>
 {r.source.author ? ` · ${r.source.author}` : ''}
 </p>
 {r.source.adaptation && (
 <p class="fine">{t.recipe.adapted}: {r.source.adaptation}</p>
 )}
 {r.origin.note && <p class="fine">{r.origin.note}</p>}
 <div class="no-print" style="margin-top: 10px;">
 <button class="chip" onclick="window.print()">🖨 {t.recipe.print}</button>
 </div>
 </section>
 </div>
 </div>

 {similar.length > 0 && (
 <section class="similar no-print">
 <h2>{t.recipe.similar}</h2>
 <div class="card-grid">
 {similar.map((e) => (
 <RecipeCard e={e} lang={lang} t={t} />
 ))}
 </div>
 </section>
 )}
 </article>
</Layout>

<style>
 .recipe {
 padding-block: clamp(20px, 3vw, 40px);
 }
 .crumbtrail {
 font-family: var(--font-mono);
 font-size: 0.78rem;
 }
 .recipe-head h1 .native {
 display: block;
 font-size: 0.45em;
 color: var(--ink-muted);
 font-style: italic;
 margin-top: 6px;
 font-variation-settings: 'SOFT' 100;
 }
 .tested-mark {
 margin: 0 0 0.8em;
 }
 .tested-mark .chip-tested {
 font-size: 0.78rem;
 }
 .tested-date {
 opacity: 0.85;
 font-weight: 400;
 }
 .kitchen-note {
 margin: 16px 0 0;
 padding: 12px 16px;
 border-left: 3px solid var(--levain);
 background: color-mix(in srgb, var(--levain) 8%, transparent);
 border-radius: 0 8px 8px 0;
 }
 .kitchen-note-label {
 font-family: var(--font-mono);
 font-size: 0.7rem;
 text-transform: uppercase;
 letter-spacing: 0.12em;
 color: var(--levain);
 margin: 0 0 4px;
 }
 .kitchen-note-text {
 margin: 0;
 font-style: italic;
 color: var(--ink);
 }
 .recipe-grid {
 display: grid;
 grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
 gap: clamp(20px, 3.5vw, 44px);
 margin-top: clamp(20px, 3vw, 36px);
 align-items: start;
 }
 @media (max-width: 900px) {
 .recipe-grid {
 grid-template-columns: 1fr;
 }
 }
 .plate {
 position: sticky;
 top: 76px;
 }
 @media (max-width: 900px) {
 .plate {
 position: static;
 }
 }
 .plate-card :global(svg) {
 width: 78%;
 margin-inline: auto;
 display: block;
 }
 table.spec td:first-child {
 color: var(--ink-muted);
 font-size: 0.88rem;
 }
 .content section {
 margin-bottom: clamp(28px, 4vw, 44px);
 }
 .method {
 list-style: none;
 padding: 0;
 margin: 0;
 counter-reset: step;
 }
 .method li {
 position: relative;
 padding: 0 0 18px 58px;
 counter-increment: step;
 }
 .method li::before {
 content: counter(step, decimal-leading-zero);
 position: absolute;
 left: 0;
 top: 2px;
 font-family: var(--font-mono);
 font-size: 0.8rem;
 color: var(--crust);
 border: 1px solid var(--line);
 border-radius: 8px;
 padding: 4px 7px;
 background: var(--surface);
 }
 .method li::after {
 content: '';
 position: absolute;
 left: 19px;
 top: 34px;
 bottom: 4px;
 width: 1px;
 background: var(--line);
 }
 .method li:last-child::after {
 display: none;
 }
 .method h3 {
 margin-bottom: 0.2em;
 }
 .method p {
 color: var(--ink-muted);
 }
 .similar {
 margin-top: clamp(36px, 5vw, 60px);
 }
 .card.soft {
 box-shadow: none;
 background: var(--paper);
 margin-top: 14px;
 }
 .lab-link {
 margin-top: 14px;
 }
</style>
