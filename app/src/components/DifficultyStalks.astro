---
interface Props {
  level: number;
  label: string;
}

const { level, label } = Astro.props;
const stalks = [1, 2, 3, 4, 5];
---

<span class="stalks" role="img" aria-label={label} title={label}>
 {stalks.map((s) => (
 <svg width="11" height="16" viewBox="0 0 11 16" aria-hidden="true" opacity={s <= level ? 1 : 0.22}>
 <path
 d="M5.5 15 V6 M5.5 8 C 3 7.5, 2 5.5, 2 3.4 C 4 3.8, 5.3 5, 5.5 7 C 5.7 5, 7 3.8, 9 3.4 C 9 5.5, 8 7.5, 5.5 8 M5.5 4.6 C 4.6 3.4, 4.6 2, 5.5 0.8 C 6.4 2, 6.4 3.4, 5.5 4.6"
 fill="none"
 stroke="var(--gold)"
 stroke-width="1.25"
 stroke-linecap="round"
 />
 </svg>
 ))}
</span>

<style>
 .stalks {
 display: inline-flex;
 gap: 1px;
 align-items: flex-end;
 }
</style>
