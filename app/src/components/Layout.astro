---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/source-serif-4';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import { getDict, LANG_NAMES, switchLangPath, withBase } from '../i18n';
import { LANGS, type Lang } from '../lib/taxonomy';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  current?: 'home' | 'atlas' | 'lab' | 'school' | 'finder' | 'about';
  image?: string;
}

const LOCALES: Record<Lang, string> = {
  en: 'en_US',
  de: 'de_DE',
  es: 'es_ES',
  fr: 'fr_FR',
  ro: 'ro_RO',
};

const { lang, title, description, current = 'home', image = '/og-default.svg' } = Astro.props;
const t = getDict(lang);
const path = Astro.url.pathname;

// Absolute canonical URL for the current page, correct under the /panarium base.
// Astro.url.pathname already includes the base, and Astro.site is the origin.
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const imageURL = new URL(withBase(image), Astro.site).href;
const ogLocale = LOCALES[lang];
const fullTitle = title === t.siteName ? title : `${title} · ${t.siteName}`;

const navItems = [
  { key: 'atlas', href: withBase(`/${lang}/breads/`), label: t.nav.atlas },
  { key: 'lab', href: withBase(`/${lang}/lab/`), label: t.nav.lab },
  { key: 'school', href: withBase(`/${lang}/school/`), label: t.nav.school },
  { key: 'finder', href: withBase(`/${lang}/finder/`), label: t.nav.finder },
  { key: 'about', href: withBase(`/${lang}/about/`), label: t.nav.about },
] as const;
const homeHref = withBase(`/${lang}/`);
---

 <html lang={lang}>
 <head>
 <meta charset="utf-8" />
 <meta name="viewport" content="width=device-width, initial-scale=1" />
 <title>{fullTitle}</title>
 <meta name="description" content={description} />
 <link rel="canonical" href={canonicalURL} />
 <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
 <meta property="og:type" content="website" />
 <meta property="og:site_name" content={t.siteName} />
 <meta property="og:locale" content={ogLocale} />
 <meta property="og:title" content={title} />
 <meta property="og:description" content={description} />
 <meta property="og:url" content={canonicalURL} />
 <meta property="og:image" content={imageURL} />
 <meta name="twitter:card" content="summary_large_image" />
 <meta name="twitter:title" content={title} />
 <meta name="twitter:description" content={description} />
 <meta name="twitter:image" content={imageURL} />
 {LANGS.map((l) => (
 <link rel="alternate" hreflang={l} href={switchLangPath(path, l)} />
 ))}
 <script is:inline>
 (() => {
 const stored = localStorage.getItem('panarium-theme');
 const dark = stored ? stored === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
 if (dark) document.documentElement.dataset.theme = 'dark';
 })();
 </script>
 </head>
 <body>
 <a class="skip-link" href="#main">↓</a>
 <header class="site-head">
 <div class="wrap bar">
 <a href={homeHref} aria-label={t.siteName} style="text-decoration:none">
 <slot name="logo">
 <span class="wordmark">
 <svg width="26" height="26" viewBox="0 0 26 26" aria-hidden="true">
 <circle cx="13" cy="13" r="11" fill="none" stroke="var(--crust)" stroke-width="2.4"></circle>
 <path d="M8 10 Q 13 6 18 10 M8 14 Q 13 10 18 14 M9.5 18 Q 13 14.6 16.5 18" fill="none" stroke="var(--crust)" stroke-width="1.8" stroke-linecap="round"></path>
 </svg>
 <span>{t.siteName}</span>
 </span>
 </slot>
 </a>
 <div class="head-panel" id="head-panel">
 <nav aria-label="main">
 {navItems.map((item) => (
 <a href={item.href} aria-current={current === item.key ? 'page' : undefined}>
 {item.label}
 </a>
 ))}
 </nav>
 <div class="lang-switch" aria-label={t.common.language}>
 {LANGS.map((l) => (
 <a href={switchLangPath(path, l)} aria-current={l === lang ? 'true' : undefined} title={LANG_NAMES[l]}>
 {l}
 </a>
 ))}
 </div>
 </div>
 <div class="head-tools">
 <button class="theme-toggle" id="theme-toggle" aria-label={t.common.theme}>
 <svg class="sun" width="15" height="15" viewBox="0 0 15 15" aria-hidden="true"><circle cx="7.5" cy="7.5" r="3.4" fill="currentColor"/><g stroke="currentColor" stroke-width="1.3" stroke-linecap="round"><path d="M7.5 0.8v1.6M7.5 12.6v1.6M0.8 7.5h1.6M12.6 7.5h1.6M2.8 2.8l1.1 1.1M11.1 11.1l1.1 1.1M12.2 2.8l-1.1 1.1M3.9 11.1l-1.1 1.1"/></g></svg>
 <svg class="moon" width="15" height="15" viewBox="0 0 15 15" aria-hidden="true"><path d="M13 9.5A6 6 0 0 1 5.5 2 6.2 6.2 0 1 0 13 9.5Z" fill="currentColor"/></svg>
 </button>
 <button class="theme-toggle menu-toggle" id="menu-toggle" aria-label={t.common.menu} aria-controls="head-panel" aria-expanded="false">
 <svg width="15" height="15" viewBox="0 0 15 15" aria-hidden="true"><g stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M1.5 3.5h12M1.5 7.5h12M1.5 11.5h12"/></g></svg>
 </button>
 </div>
 </div>
 </header>
 <main id="main">
 <slot />
 </main>
 <footer class="site-foot">
 <div class="wrap cols">
 <div>
 <span class="wordmark small">
 <svg width="18" height="18" viewBox="0 0 26 26" aria-hidden="true">
 <circle cx="13" cy="13" r="11" fill="none" stroke="var(--crust)" stroke-width="2.4"></circle>
 <path d="M8 10 Q 13 6 18 10 M8 14 Q 13 10 18 14 M9.5 18 Q 13 14.6 16.5 18" fill="none" stroke="var(--crust)" stroke-width="1.8" stroke-linecap="round"></path>
 </svg>
 {t.siteName}
 </span>
 <p style="margin-top:10px">{t.tagline}. {t.footer.dataNote}</p>
 </div>
 <div>
 <h4>{t.footer.sections}</h4>
 <ul>
 {navItems.map((item) => (
 <li><a href={item.href}>{item.label}</a></li>
 ))}
 </ul>
 </div>
 <div>
 <h4>{t.footer.languages}</h4>
 <ul>
 {LANGS.map((l) => (
 <li><a href={switchLangPath(path, l)}>{LANG_NAMES[l]}</a></li>
 ))}
 </ul>
 </div>
 </div>
 </footer>
 <script>
 const btn = document.getElementById('theme-toggle');
 btn?.addEventListener('click', () => {
 const root = document.documentElement;
 const dark = root.dataset.theme === 'dark';
 if (dark) delete root.dataset.theme;
 else root.dataset.theme = 'dark';
 localStorage.setItem('panarium-theme', dark ? 'light' : 'dark');
 });

 // Collapsible header on narrow screens. Above the breakpoint the panel is
 // always visible through CSS, so this only matters on small viewports.
 const menuBtn = document.getElementById('menu-toggle');
 const panel = document.getElementById('head-panel');
 if (menuBtn && panel) {
 const setOpen = (open) => {
 panel.classList.toggle('open', open);
 menuBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
 };
 menuBtn.addEventListener('click', () => {
 setOpen(menuBtn.getAttribute('aria-expanded') !== 'true');
 });
 panel.addEventListener('click', (e) => {
 if (e.target instanceof Element && e.target.closest('a')) setOpen(false);
 });
 document.addEventListener('keydown', (e) => {
 if (e.key === 'Escape') setOpen(false);
 });
 }
 </script>
 <style>
 .wordmark {
 display: inline-flex;
 align-items: center;
 gap: 9px;
 font-family: var(--font-display);
 font-variation-settings: 'SOFT' 80, 'WONK' 1;
 font-weight: 620;
 font-size: 1.32rem;
 color: var(--ink);
 letter-spacing: -0.01em;
 }
 .wordmark.small {
 font-size: 1.05rem;
 }
 </style>
 </body>
</html>
